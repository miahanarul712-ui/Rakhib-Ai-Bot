import os
import google.generativeai as genai
from telegram import Update
from telegram.ext import Application, CommandHandler, MessageHandler, ContextTypes, filters

# Environment Variables
BOT_TOKEN = os.getenv("BOT_TOKEN")
GEMINI_API_KEY = os.getenv("GEMINI_API_KEY")

# Gemini AI
genai.configure(api_key=GEMINI_API_KEY)
model = genai.GenerativeModel("gemini-2.5-flash")

# /start command
async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text(
        "🤖 স্বাগতম Rakhib AI Study Bot!\n\n"
        "আমি বাংলা, English এবং Hindi ভাষায় পড়াশোনা ও সাধারণ প্রশ্নের উত্তর দিতে পারি।"
    )

# Message handler
async def reply(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_text = update.message.text

    if "কে বানিয়েছে" in user_text or "who made you" in user_text.lower():
        await update.message.reply_text("আমাকে Rakhib Miah তৈরি করেছেন।")
        return

    try:
        response = model.generate_content(user_text)
        await update.message.reply_text(response.text)
    except Exception:
        await update.message.reply_text("দুঃখিত, এই মুহূর্তে উত্তর দিতে পারছি না।")

# Run Bot
app = Application.builder().token(BOT_TOKEN).build()

app.add_handler(CommandHandler("start", start))
app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, reply))

print("Rakhib AI Study Bot is running...")
app.run_polling()
